---
import { MessageCircle, ClipboardList, CreditCard, Plane } from 'lucide-react';

const steps = [
	{
		icon: MessageCircle,
		title: 'Konsultasi Gratis',
		body: 'Ceritakan destinasi impian, budget, dan preferensi. Kami dengarkan dulu.'
	},
	{
		icon: ClipboardList,
		title: 'Custom Itinerary',
		body: 'Kami kirim proposal lengkap: rute, hotel, harga breakdown, dalam 24 jam.'
	},
	{
		icon: CreditCard,
		title: 'Konfirmasi & DP',
		body: 'Setuju dengan proposal? DP 30% untuk lock jadwal & harga.'
	},
	{
		icon: Plane,
		title: 'Berangkat & Nikmati',
		body: 'Kami dampingi dari check-in sampai pulang. Fokus menikmati perjalanan.'
	}
];
---

<section class="mx-auto max-w-[1280px] px-6 py-16">
	<h2 class="text-3xl font-bold text-ink md:text-4xl">Pesan Perjalananmu dalam 4 Langkah</h2>

	<ol class="mt-10 grid grid-cols-1 gap-8 md:grid-cols-4">
		{
			steps.map((step, i) => (
				<li class="step-reveal relative" style={`transition-delay:${i * 120}ms`}>
					<span class="flex h-12 w-12 items-center justify-center rounded-full bg-primary-teal text-lg font-bold text-white">
						{i + 1}
					</span>
					<step.icon className="mt-4 h-8 w-8 text-primary-teal" strokeWidth={1.75} />
					<h3 class="mt-2 text-lg font-semibold text-ink">{step.title}</h3>
					<p class="mt-1 text-sm text-body">{step.body}</p>
				</li>
			))
		}
	</ol>
</section>

<style>
	.step-reveal {
		opacity: 0;
		transform: translateY(24px);
		transition:
			opacity 0.6s ease,
			transform 0.6s ease;
	}
	.step-reveal.is-visible {
		opacity: 1;
		transform: translateY(0);
	}
</style>

<script>
	const steps = document.querySelectorAll('.step-reveal');
	const observer = new IntersectionObserver(
		(entries) => {
			for (const entry of entries) {
				if (entry.isIntersecting) entry.target.classList.add('is-visible');
			}
		},
		{ threshold: 0.3 }
	);
	steps.forEach((step) => observer.observe(step));
</script>
