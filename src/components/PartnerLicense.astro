---
const licenses = ['ASITA', 'IATA', 'Kemenparekraf RI', 'ASTINDO'];
const airlines = ['Garuda Indonesia', 'Lion Air', 'AirAsia', 'Singapore Airlines', 'Emirates'];
---

<section class="border-y border-hairline py-12">
	<div class="mx-auto max-w-[1280px] px-6">
		<h2 class="text-center text-xl font-semibold text-ink">Terdaftar & Berlisensi Resmi</h2>

		<div class="mt-6 flex flex-wrap items-center justify-center gap-x-10 gap-y-4">
			{
				licenses.map((license) => (
					<span class="text-sm font-semibold text-primary-teal">{license}</span>
				))
			}
		</div>

		<div class="mt-8 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 border-t border-hairline-soft pt-6">
			{
				airlines.map((airline) => (
					<span class="text-sm text-muted">{airline}</span>
				))
			}
		</div>
	</div>
</section>
