---
const navItems = [
	{ label: 'Paket Tour', href: '#paket-tour' },
	{ label: 'Destinasi', href: '#destinasi' },
	{ label: 'Honeymoon', href: '#honeymoon' },
	{ label: 'MICE', href: '#mice' },
	{ label: 'Blog', href: '#blog' }
];
---

<header class="sticky top-0 z-50 h-20 border-b border-hairline bg-canvas/95 backdrop-blur">
	<div class="mx-auto flex h-full max-w-[1280px] items-center justify-between px-6">
		<a href="/" class="font-serif text-xl text-ink">Nusantara Journey</a>

		<nav class="hidden items-center gap-8 md:flex">
			{
				navItems.map((item) => (
					<a
						href={item.href}
						class="text-base font-semibold text-ink transition-colors hover:text-primary-teal"
					>
						{item.label}
					</a>
				))
			}
		</nav>

		<a
			href="#booking"
			class="rounded-sm bg-cta-gold px-6 py-3 text-base font-medium text-white transition-colors hover:bg-cta-gold-active"
		>
			Konsultasi Trip Gratis
		</a>
	</div>
</header>
